node_modules/
*.tsbuildinfo

# dist/ is intentionally committed: n8n's verification pre-check resolves the
# paths in package.json's `n8n` block (dist/credentials/…, dist/nodes/…) against
# the GitHub repo, not the npm tarball. The ci.yml drift-guard keeps it in sync.

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor / OS
.DS_Store
.idea/
.vscode/
*.log

# env
.env
.env.*

# internal planning artifact, not part of the package
PLAN.md

# local n8n container staging dir
.n8n-custom/

# npm pack output (a bare `npm pack` drops the tarball in the repo root)
*.tgz

# test coverage
coverage/
.vitest/
